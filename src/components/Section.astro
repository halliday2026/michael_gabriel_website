---
import Container from './Container.astro';

interface Props {
  tone?: 'default' | 'muted';
  id?: string;
  class?: string;
}

const { tone = 'default', id, class: className = '' } = Astro.props;
---

<section
  id={id}
  class:list={[
    'py-16 sm:py-24',
    tone === 'muted' ? 'bg-muted' : 'bg-surface',
    className,
  ]}
>
  <Container>
    <slot />
  </Container>
</section>
