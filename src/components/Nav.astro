---
import { site } from '../data/site';
---

<header class="sticky top-0 z-50 border-b border-muted bg-surface/95 backdrop-blur supports-[backdrop-filter]:bg-surface/80">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8" aria-label="Primary">
    <a href="#main" class="font-display text-lg font-bold text-brand">
      {site.name}
    </a>

    <button
      id="nav-toggle"
      type="button"
      class="inline-flex items-center justify-center rounded-(--radius) p-2 text-brand sm:hidden"
      aria-expanded="false"
      aria-controls="nav-menu"
    >
      <span class="sr-only">Toggle navigation menu</span>
      <svg id="nav-icon-open" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="nav-icon-close" xmlns="http://www.w3.org/2000/svg" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <ul id="nav-menu" class="hidden flex-col gap-2 sm:flex sm:flex-row sm:items-center sm:gap-6">
      {site.nav.map((item) => (
        <li>
          <a
            href={item.href}
            class="block rounded-(--radius) px-2 py-1 font-medium text-ink hover:text-accent"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-menu');
  const iconOpen = document.getElementById('nav-icon-open');
  const iconClose = document.getElementById('nav-icon-close');

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
    menu?.classList.toggle('flex');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });
</script>
