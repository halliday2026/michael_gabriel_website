---
import { site, content } from '../data/site';

const enNav = content.en.nav;
---

<header class="sticky top-0 z-50 border-b border-muted bg-surface/95 backdrop-blur supports-[backdrop-filter]:bg-surface/80">
  <nav class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6 lg:px-8" aria-label="Primary">

    <!-- Logo mark -->
    <a href="#main" class="shrink-0" aria-label={site.name}>
      <img
        src={`${import.meta.env.BASE_URL}header_logo.png`}
        alt="Icon of the Holy Archangels Michael and Gabriel"
        height="48"
        class="h-10 w-auto object-contain sm:h-12"
      />
    </a>

    <!-- Right side: desktop nav + lang switcher + mobile toggle -->
    <div class="flex items-center gap-4">

      <!-- Desktop nav links -->
      <ul id="nav-menu" class="hidden flex-col gap-2 sm:flex sm:flex-row sm:items-center sm:gap-5">
        {site.nav.map((item) => (
          <li>
            <a
              href={item.href}
              data-i18n={`nav.${item.key}`}
              class="block rounded-(--radius) px-2 py-1 text-sm font-medium text-ink hover:text-accent"
            >
              {enNav[item.key as keyof typeof enNav]}
            </a>
          </li>
        ))}
      </ul>

      <!-- Language toggle -->
      <div class="hidden items-center gap-1 sm:flex" aria-label="Language">
        {(['en', 'es', 'ro'] as const).map((lang) => (
          <button
            data-lang={lang}
            type="button"
            class={[
              'rounded-(--radius) border px-3 py-1 text-xs font-bold tracking-wide transition-all',
              lang === 'en'
                ? 'border-accent bg-accent text-brand shadow-sm'
                : 'border-ink/20 bg-transparent text-ink/50 hover:border-accent hover:text-accent',
            ].join(' ')}
          >
            {lang.toUpperCase()}
          </button>
        ))}
      </div>

      <!-- Mobile hamburger -->
      <button
        id="nav-toggle"
        type="button"
        class="inline-flex items-center justify-center rounded-(--radius) p-2 text-brand sm:hidden"
        aria-expanded="false"
        aria-controls="nav-mobile-menu"
      >
        <span class="sr-only">Toggle navigation menu</span>
        <svg id="nav-icon-open" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="nav-icon-close" xmlns="http://www.w3.org/2000/svg" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile dropdown menu -->
  <div id="nav-mobile-menu" class="hidden border-t border-muted bg-surface px-4 pb-4 pt-2 sm:hidden">
    <ul class="flex flex-col gap-1">
      {site.nav.map((item) => (
        <li>
          <a
            href={item.href}
            data-i18n={`nav.${item.key}`}
            class="block rounded-(--radius) px-2 py-2 text-sm font-medium text-ink hover:text-accent"
          >
            {enNav[item.key as keyof typeof enNav]}
          </a>
        </li>
      ))}
    </ul>
    <!-- Mobile language toggle -->
    <div class="mt-3 flex items-center gap-2 border-t border-muted pt-3" aria-label="Language">
      <span class="text-xs font-medium text-ink/40">Language:</span>
      {(['en', 'es', 'ro'] as const).map((lang) => (
        <button
          data-lang={lang}
          type="button"
          class={[
            'rounded-(--radius) border px-3 py-1.5 text-xs font-bold tracking-wide transition-all',
            lang === 'en'
              ? 'border-accent bg-accent text-brand shadow-sm'
              : 'border-ink/20 bg-transparent text-ink/50 hover:border-accent hover:text-accent',
          ].join(' ')}
        >
          {lang.toUpperCase()}
        </button>
      ))}
    </div>
  </div>
</header>

<script>
  // Mobile menu toggle
  const toggle = document.getElementById('nav-toggle');
  const mobileMenu = document.getElementById('nav-mobile-menu');
  const iconOpen = document.getElementById('nav-icon-open');
  const iconClose = document.getElementById('nav-icon-close');

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    mobileMenu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });

  // Close mobile menu on nav link click
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    });
  });
</script>
