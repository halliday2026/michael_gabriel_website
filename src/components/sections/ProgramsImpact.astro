---
import Section from '../Section.astro';
import { site } from '../../data/site';

const { programsImpact } = site;
---

<Section id="programs" tone="default">
  <h2 class="font-display text-3xl font-bold text-brand">{programsImpact.heading}</h2>

  <ul class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {programsImpact.items.map((item) => (
      <li class="rounded-(--radius) bg-muted p-6">
        <span class="text-3xl" aria-hidden="true">{item.icon}</span>
        <h3 class="mt-4 font-display text-xl font-semibold text-brand">{item.heading}</h3>
        <p class="mt-2 text-ink/80">{item.blurb}</p>
      </li>
    ))}
  </ul>
</Section>
