---
import Section from '../Section.astro';
import { content } from '../../data/site';

const { welcome } = content.en;
---

<Section id="welcome" tone="muted">
  <div class="max-w-3xl">
    <h2
      class="font-display text-3xl font-bold text-brand sm:text-4xl"
      data-i18n="welcome.heading"
    >
      {welcome.heading}
    </h2>

    <div class="mt-6 space-y-4 text-lg leading-relaxed text-ink/80">
      <p data-i18n="welcome.body1">{welcome.body1}</p>
      <p data-i18n="welcome.body2">{welcome.body2}</p>
      <p data-i18n="welcome.body3">{welcome.body3}</p>
    </div>

    <!-- Calendar link -->
    <a
      href="https://www.noutati-ortodoxe.ro/calendar-ortodox/"
      target="_blank"
      rel="noopener noreferrer"
      class="mt-8 inline-flex items-center gap-2 rounded-(--radius) border border-accent/30 bg-accent/10 px-4 py-2 text-sm font-medium text-ink/70 transition-colors hover:border-accent hover:bg-accent/20 hover:text-ink"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 shrink-0">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
      </svg>
      <span data-i18n="welcome.calendarNote">{welcome.calendarNote}</span>
    </a>
  </div>
</Section>
