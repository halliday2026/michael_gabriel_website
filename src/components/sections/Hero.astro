---
import Section from '../Section.astro';
import Button from '../Button.astro';
import { site } from '../../data/site';

const { hero } = site;
---

<Section tone="default" class="pt-12 sm:pt-16">
  <div class="grid items-center gap-10 lg:grid-cols-2">
    <div>
      <h1 class="font-display text-4xl font-bold tracking-tight text-brand sm:text-5xl">
        {hero.headline}
      </h1>
      <p class="mt-4 max-w-prose text-lg text-ink/80">
        {hero.subhead}
      </p>
      <div class="mt-8">
        <Button href={hero.ctaHref}>{hero.ctaLabel}</Button>
      </div>
    </div>

    <div class="overflow-hidden rounded-(--radius) bg-muted">
      <slot name="image">
        <img
          src="/favicon.svg"
          alt={hero.imageAlt}
          width="640"
          height="480"
          class="aspect-4/3 h-full w-full object-contain p-12"
        />
      </slot>
    </div>
  </div>
</Section>
