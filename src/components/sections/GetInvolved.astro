---
import Section from '../Section.astro';
import Button from '../Button.astro';
import { site } from '../../data/site';

const { getInvolved } = site;
---

<Section id="get-involved" tone="default">
  <div class="rounded-(--radius) bg-brand px-8 py-12 text-center text-surface">
    <h2 class="font-display text-3xl font-bold">{getInvolved.heading}</h2>
    <p class="mx-auto mt-4 max-w-prose text-lg text-surface/90">{getInvolved.body}</p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
      <Button href={getInvolved.donateHref} variant="solid" class="bg-highlight hover:bg-accent">
        {getInvolved.donateLabel}
      </Button>
      <Button href={getInvolved.volunteerHref} variant="outline" class="border-surface text-surface hover:bg-surface hover:text-brand">
        {getInvolved.volunteerLabel}
      </Button>
    </div>
  </div>
</Section>
