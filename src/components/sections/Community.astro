---
import Section from '../Section.astro';
import { content } from '../../data/site';

const { community } = content.en;

const base = import.meta.env.BASE_URL;
const carouselImages = [
  { src: `${base}carousel/front.jpg`,   alt: 'Church front' },
  { src: `${base}carousel/kids.jpg`,    alt: 'Children at church' },
  { src: `${base}carousel/night.jpg`,   alt: 'Evening gathering' },
  { src: `${base}carousel/picnic.jpg`,  alt: 'Parish picnic' },
  { src: `${base}carousel/service.jpg`, alt: 'Divine Liturgy' },
  { src: `${base}carousel/side.jpg`,    alt: 'Church exterior', position: 'center 80%' },
];
---

<Section id="community" tone="muted">
  <h2
    class="font-display text-3xl font-bold text-brand sm:text-4xl"
    data-i18n="community.heading"
  >
    {community.heading}
  </h2>

  <img
    src={`${base}community.jpg`}
    alt="Parish community gathering"
    class="mt-6 w-full max-w-3xl rounded-(--radius) object-cover shadow-md"
  />

  <p
    class="mt-6 max-w-3xl text-lg leading-relaxed text-ink/80"
    data-i18n="community.body"
  >
    {community.body}
  </p>

  <!-- Image carousel -->
  <div class="relative mt-10 w-full overflow-hidden rounded-(--radius) shadow-lg" id="community-carousel">
    <!-- Track -->
    <div
      class="flex transition-transform duration-500 ease-in-out"
      id="carousel-track"
    >
      {carouselImages.map((img) => (
        <img
          src={img.src}
          alt={img.alt}
          class="w-full shrink-0 object-cover aspect-video"
          style={img.position ? `object-position: ${img.position}` : undefined}
          loading="lazy"
        />
      ))}
    </div>

    <!-- Prev button -->
    <button
      id="carousel-prev"
      aria-label="Previous image"
      class="absolute left-3 top-1/2 -translate-y-1/2 flex h-10 w-10 items-center justify-center rounded-full bg-brand/70 text-surface backdrop-blur-sm transition hover:bg-brand"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><polyline points="15 18 9 12 15 6"/></svg>
    </button>

    <!-- Next button -->
    <button
      id="carousel-next"
      aria-label="Next image"
      class="absolute right-3 top-1/2 -translate-y-1/2 flex h-10 w-10 items-center justify-center rounded-full bg-brand/70 text-surface backdrop-blur-sm transition hover:bg-brand"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><polyline points="9 18 15 12 9 6"/></svg>
    </button>

    <!-- Dot indicators -->
    <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-2" id="carousel-dots">
      {carouselImages.map((_, i) => (
        <button
          aria-label={`Go to image ${i + 1}`}
          class={`h-2 w-2 rounded-full transition-all ${i === 0 ? 'bg-surface w-4' : 'bg-surface/50'}`}
          data-index={i}
        />
      ))}
    </div>
  </div>
</Section>

<script>
  const track    = document.getElementById('carousel-track') as HTMLElement;
  const dots     = document.querySelectorAll<HTMLButtonElement>('#carousel-dots button');
  const total    = dots.length;
  let current    = 0;
  let timer: ReturnType<typeof setInterval>;

  function goTo(index: number) {
    current = (index + total) % total;
    track.style.transform = `translateX(-${current * 100}%)`;
    dots.forEach((dot, i) => {
      dot.classList.toggle('bg-surface', i === current);
      dot.classList.toggle('w-4', i === current);
      dot.classList.toggle('bg-surface/50', i !== current);
      dot.classList.toggle('w-2', i !== current);
    });
  }

  function startTimer() {
    timer = setInterval(() => goTo(current + 1), 4000);
  }

  function resetTimer() {
    clearInterval(timer);
    startTimer();
  }

  document.getElementById('carousel-prev')!.addEventListener('click', () => { goTo(current - 1); resetTimer(); });
  document.getElementById('carousel-next')!.addEventListener('click', () => { goTo(current + 1); resetTimer(); });
  dots.forEach((dot) => dot.addEventListener('click', () => { goTo(Number(dot.dataset.index)); resetTimer(); }));

  // Pause on hover
  const carousel = document.getElementById('community-carousel')!;
  carousel.addEventListener('mouseenter', () => clearInterval(timer));
  carousel.addEventListener('mouseleave', startTimer);

  startTimer();
</script>
