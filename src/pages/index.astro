---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import Welcome from '../components/sections/Welcome.astro';
import DivineLiturgies from '../components/sections/DivineLiturgies.astro';
import Clergy from '../components/sections/Clergy.astro';
import Community from '../components/sections/Community.astro';
import VisitUs from '../components/sections/VisitUs.astro';
import Donate from '../components/sections/Donate.astro';
import Contact from '../components/sections/Contact.astro';
import { site, content } from '../data/site';
---

<BaseLayout title={content.en.hero.headline} description={site.description}>
  <Hero />
  <Welcome />
  <DivineLiturgies />
  <Clergy />
  <Community />
  <VisitUs />
  <Donate />
  <Contact />
</BaseLayout>
