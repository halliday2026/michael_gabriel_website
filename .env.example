# Copy this file to `.env` for local overrides. None of these are required to
# run `npm run dev` — sensible staging fallbacks live in astro.config.mjs and
# src/data/site.ts. All fallbacks use `||` (not `??`) on purpose: CI sometimes
# passes env vars as an empty string '', and `??` only falls back on
# null/undefined, so an empty string would slip through and break the build.
# `||` correctly treats '' as "not set".

# --- Deployment target -------------------------------------------------
# Full origin the site is served from, e.g. https://USERNAME.github.io
# (staging / GitHub Pages project site) or https://www.yourclient.org
# (production / custom domain).
SITE_URL=

# Base path the site is served under. For a GitHub Pages project site this
# is "/REPO-NAME/". For a custom domain at the root, use "/".
BASE_PATH=

# --- Indexing -----------------------------------------------------------
# Controls whether pages emit <meta name="robots" content="noindex, nofollow">.
# Defaults to "true" (noindex ON) so staging never leaks into search results.
# Set to "false" ONLY when flipping a site to production. Leaving this unset
# (or set to anything other than the literal string "false") keeps noindex on.
NOINDEX=true

# --- Contact form --------------------------------------------------------
# Formspree form endpoint, e.g. https://formspree.io/f/abc123
PUBLIC_FORMSPREE_ENDPOINT=

# --- Analytics (optional) ------------------------------------------------
# Analytics only render when an ID is present AND NOINDEX=false, so staging
# traffic never pollutes production analytics.
PUBLIC_GA4_ID=
PUBLIC_CLARITY_ID=
